{
  "name": "lcu-decomp",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Dev machine: Apple Silicon Mac (arm64).
  // The container runs NATIVELY as linux/arm64 — no Rosetta 2, no qemu.
  // --platform is kept explicit so the image arch is locked to arm64 and the
  // native aarch64-Linux Clang 3.9.1 prebuilt is used (see Dockerfile header).
  //
  // --env-file mounts the (gitignored) .env so the GitHub API token is
  // available inside the container. The file must exist locally (it holds
  // GITHUB_TOKEN); it never enters the image or version control.
  "runArgs": [
    "--platform=linux/arm64",
    "--env-file",
    "${localWorkspaceFolder}/.env"
  ],

  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "llvm-vs-code-extensions.vscode-clangd",
        "twxs.cmake",
        "eamodio.gitlens"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "clangd.arguments": ["--compile-commands-dir=build"]
      }
    }
  },

  // Set up the project toolchain WITHOUT the game binary (clean-room: the NSO
  // is never committed and never baked into the image). This downloads the
  // native aarch64-Linux Clang 3.9.1 + check/listsym/decompme + libc++ headers
  // and creates the build/ directory.
  //
  // To add the original executable later, run inside the container:
  //   tools/setup.py /path/to/main        (EU v1.0.3 main NSO)
  "postCreateCommand": "git submodule update --init --recursive && python3 tools/setup.py --project-only || echo 'setup.py failed (network?); rerun tools/setup.py --project-only'",
  "remoteUser": "decomp"
}
